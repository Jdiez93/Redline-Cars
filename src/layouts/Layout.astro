            R
          </span>
          <div class="leading-tight">
            <p class="text-sm font-semibold tracking-[0.15em] uppercase">
              RACINGPAGE
            </p>
            <p class="text-xs text-slate-300">Coches deportivos, clásicos, eléctricos...</p>
          </div>
        </a>

        <!-- Menú escritorio -->
        <div class="hidden items-center gap-6 text-sm font-medium md:flex">
  <a href="/" class="hover:text-red-400 transition-colors">Inicio</a>
  <a href="/coches" class="hover:text-red-400 transition-colors">Coches</a>
  <a href="/comparador" class="hover:text-red-400 transition-colors">Comparador</a>
  <a href="/concesionarios" class="hover:text-red-400 transition-colors">Concesionarios</a>
  <a href="/sobre-nosotros" class="hover:text-red-400 transition-colors">Sobre nosotros</a>
</div>

        <!-- Menú móvil -->
        <details class="relative md:hidden">
          <summary class="list-none flex items-center cursor-pointer">
            <span class="sr-only">Abrir menú</span>
            <div class="flex h-9 w-9 items-center justify-center rounded-full border border-red-500/70 bg-black/70">
              <div class="space-y-1.5">
                <span class="block h-0.5 w-5 bg-red-500"></span>
                <span class="block h-0.5 w-5 bg-red-500"></span>
                <span class="block h-0.5 w-5 bg-red-500"></span>
              </div>
            </div>
          </summary>

          <div class="flex flex-col gap-2">
  <a href="/" class="hover:text-red-400 transition-colors">Inicio</a>
  <a href="/coches" class="hover:text-red-400 transition-colors">Coches</a>
  <a href="/comparador" class="hover:text-red-400 transition-colors">Comparador</a>
  <a href="/concesionarios" class="hover:text-red-400 transition-colors">Concesionarios</a>
  <a href="/sobre-nosotros" class="hover:text-red-400 transition-colors">Sobre nosotros</a>
</div>
        </details>
      </nav>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="flex-1">
      <slot />
    </main>

        <!-- FOOTER -->
    <footer class="mt-10 border-t border-red-600/40 bg-black/95">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

        <!-- COLUMNA 1: SOBRE EL PROYECTO -->
