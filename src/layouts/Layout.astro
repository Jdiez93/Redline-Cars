          <h3 class="text-sm font-semibold uppercase tracking-wide text-red-400">Creador del proyecto</h3>
          <p class="text-sm text-slate-300">
            <span class="font-semibold text-white">Nombre:</span> Jorge Díez Rodríguez
          </p>
          <p class="text-sm text-slate-300">
            <span class="font-semibold text-white">Correo:</span>  
            <a href="mailto:jorgediezrodriguez2004@gmail.com" class="text-red-400 hover:text-red-300 transition">
              jorgediezrodriguez2004@gmail.com
            </a>
          </p>
          <p class="text-sm text-slate-300">
            <span class="font-semibold text-white">Ubicación:</span> España
          </p>
        </div>

        <!-- COLUMNA 3: REDES SOCIALES -->
        <div class="space-y-3">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-red-400">Redes sociales</h3>
          <ul class="space-y-2 text-sm text-slate-300">
            <li>
              <a href="https://www.linkedin.com/in/jorge-diez-rodriguez-4a7844293/" class="hover:text-red-400 transition">Linkedin</a>
            </li>
            
            <li>
              <a href="" class="hover:text-red-400 transition">GitHub del proyecto</a>
            </li>
          </ul>
        </div>

        <!-- COLUMNA 4: ENLACES ÚTILES -->
        <div class="space-y-3">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-red-400">Enlaces útiles</h3>
          <ul class="space-y-2 text-sm text-slate-300">
            <li><a href="/" class="hover:text-red-400 transition">Inicio</a></li>
            <li><a href="/coches" class="hover:text-red-400 transition">Catálogo de coches</a></li>
            <li><a href="/comparador" class="hover:text-red-400 transition">Comparador</a></li>
