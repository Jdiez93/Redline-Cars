      <!-- BARRA INFERIOR -->
      <div class="border-t border-red-600/40 bg-black/90">
        <div class="mx-auto max-w-6xl px-4 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between text-xs text-slate-500">
          
