            Desarrollado por <span class="text-red-400">Jorge Díez Rodríguez</span> · Inspirado en el automovilismo.
          </p>
        </div>
      </div>
    </footer>


            <!-- Script de animaciones de scroll (soporta contenido dinámico) -->
    <script is:inline>
      if (typeof window !== 'undefined' && !window.__redlineScrollAnimationsInit) {
        window.__redlineScrollAnimationsInit = true;

        const observed = new WeakSet();
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const target = entry.target;
              if (entry.isIntersecting) {
                target.classList.add('is-visible');
              } else {
                // Si quieres que solo se animen una vez, comenta la línea siguiente
                target.classList.remove('is-visible');
              }
            });
          },
          { threshold: 0.15 }
        );

        const scanElements = () => {
          const elements = document.querySelectorAll('[data-animate]');
          elements.forEach((el) => {
            if (!observed.has(el)) {
              const delay = el.getAttribute('data-animate-delay');
              if (delay) {
                el.style.transitionDelay = delay + 'ms';
              }
              observer.observe(el);
              observed.add(el);
            }
          });
        };

        // Escaneamos al inicio
        scanElements();

        // Y también cada vez que cambie el DOM (por ejemplo, al filtrar en React)
        const mutationObserver = new MutationObserver(() => {
          scanElements();
        });

        mutationObserver.observe(document.body, {
          childList: true,
          subtree: true,
        });
      }
    </script>

  </body>
</html>
